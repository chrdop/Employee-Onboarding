# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://onboarding:onboarding@localhost:5432/onboarding?schema=public"

# Backend
PORT=4000
JWT_SECRET="change-me-to-a-long-random-string"
CLIENT_ORIGIN="http://localhost:5173"

# Local file storage for task resources (server/uploads by default)
UPLOAD_DIR="./uploads"
